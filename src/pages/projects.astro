---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Technical Support L2 — Payments & Integrations</div>
    <p class="text-lg text-base-content/70 mb-10 max-w-3xl">
      Escalated technical support cases, troubleshooting of payment flows, API/webhook issues,
      and merchant integration assistance. Focused on fast resolution and improving support processes.
    </p>
  </div>

  <HorizontalCard
    title="L2 Technical Support for Payment Gateways"
    img="/My_photo_AI.jpg"
    desc="Handled complex escalated tickets: failed transactions, webhook delivery failures, API errors, and integration issues with Stripe and other PSPs. Created troubleshooting guides that reduced average resolution time."
    url="#"
    badge="L2 Support"
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="Checkout Flow & 3DS Troubleshooting"
    img="/My_photo_AI.jpg"
    desc="Supported merchants with advanced checkout problems including 3DS 2.0 declines, tokenization, saved cards, and high decline rates. Worked with dev and compliance teams to identify and fix root causes."
    url="#"
    badge="Payments"
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="Webhook & API Integration Support"
    img="/My_photo_AI.jpg"
    desc="Diagnosed webhook issues, retry mechanisms, and event handling for payment confirmations, refunds, and disputes. Significantly improved reliability of merchant notifications."
    url="#"
    badge="API & Webhooks"
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="Merchant Onboarding & Technical Integration"
    img="/My_photo_AI.jpg"
    desc="Assisted merchants with technical setup of payment integrations (API keys, test/live mode, webhook configuration). Resolved common errors in WooCommerce, Shopify, and custom platforms."
    url="#"
    badge="Onboarding"
  />
</BaseLayout>
