---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
    <div class="text-5xl font-bold">Konstantin Ronenko</div>
    <div class="text-3xl py-3 font-bold">Technical Support Specialist Level 2 — Payments</div>
    
    <div class="py-4 text-lg leading-relaxed max-w-2xl">
      I provide advanced technical support for payment integrations and merchant platforms.
      Experienced in troubleshooting escalated tickets, diagnosing API/webhook issues,
      resolving checkout problems, and helping merchants successfully integrate with payment gateways.
    </div>

    <div class="mt-8 flex gap-4">
      <a href="/cv" class="btn btn-primary">View Full CV</a>
      <a href="/projects" class="btn btn-outline">View My Projects</a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-5">Featured Technical Cases</div>
  </div>

  <HorizontalCard
    title="L2 Payment Gateway Support"
    img="/My_photo_AI.jpg"
    desc="Handled escalated tickets involving failed transactions, webhook failures, and API integration issues with Stripe and other PSPs."
    url="/projects"
    badge="L2 Support"
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="Advanced Checkout Troubleshooting"
    img="/My_photo_AI.jpg"
    desc="Diagnosed and resolved complex checkout problems including 3DS declines, tokenization issues, and high decline rates for merchants."
    url="/projects"
    badge="Payments"
  />

  <div class="mt-16">
    <div class="text-3xl w-full font-bold mb-5">Latest from Blog</div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + createSlug(post.data.title, post.slug)}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
